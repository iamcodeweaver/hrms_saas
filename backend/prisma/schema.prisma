generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum UserRoleType {
  SUPER_ADMIN
  HR
  MANAGER
  EMPLOYEE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LoanStatus {
  PENDING
  APPROVED
  ACTIVE
  REJECTED
  PAID
}

enum WalletTxnType {
  CREDIT
  DEBIT
}

enum WalletTxnStatus {
  PENDING
  COMPLETED
  FAILED
}

enum ApplicationStatus {
  APPLIED
  SHORTLISTED
  INTERVIEW
  OFFERED
  HIRED
  REJECTED
}

enum PayrollStatus {
  DRAFT
  PROCESSED
  PAID
}

enum ShiftType {
  MORNING
  AFTERNOON
  NIGHT
  FLEX
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum PayrollItemType {
  EARNING
  DEDUCTION
  BONUS
  TAX
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
  TEMPORARY
}

enum EmploymentStatus {
  ACTIVE
  TERMINATED
  SUSPENDED
  RESIGNED
}

enum NotificationType {
  INFO
  WARNING
  SUCCESS
  ERROR
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

//////////////////////////////////////////////////////
// TENANT CORE
//////////////////////////////////////////////////////

model Company {
  id   String @id @default(uuid())
  name String
  slug String @unique

  timezone String @default("Africa/Lagos")
  currency String @default("NGN")
  locale   String @default("en")

  users       User[]
  employees   Employee[]
  branches    Branch[]
  departments Department[]
  positions   Position[]
  wallets     Wallet[]
  roles       Role[]
  shifts      Shift[]

  recruitmentStages RecruitmentStage[]
  payrollRuns       PayrollRun[]
  leaveTypes        LeaveType[]
  biometricDevices  BiometricDevice[]
  settings          CompanySetting?

  auditLogs DomainAuditLog[]
  events    DomainEvent[]

  subscriptions Subscription[]
  policies      Policy[]

  // ADD THESE
  walletTransactions  WalletTransaction[]
  leaveRequests       LeaveRequest[]
  applicants          Applicant[]
  jobPositions        JobPosition[]
  jobApplications     JobApplication[]
  payrolls            Payroll[]
  attendanceLogs      AttendanceLog[]
  attendanceSummaries AttendanceSummary[]
  files               File[]
  loans               Loan[]

  assets         Asset[]
  inventoryItems InventoryItem[]
  integrations   Integration[]

  reports Report[]
  kpis    KPI[]

  // 🔧 Training & Development relations
  trainingPrograms TrainingProgram[] // opposite side of TrainingProgram.company

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  attendanceSessions AttendanceSession[]
  broadcastMessages  BroadcastMessage[]
}

//////////////////////////////////////////////////////
// USERS + RBAC
//////////////////////////////////////////////////////

model User {
  id       String  @id @default(uuid())
  email    String
  password String
  isActive Boolean @default(true)

  emailVerifiedAt DateTime?

  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?
  passwordChangedAt   DateTime?

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  employee Employee?

  roles UserRoleMap[]

  approvedLeaves LeaveRequest[] // NEW

  refreshTokens RefreshToken[]
  auditLogs     DomainAuditLog[]

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  broadcastMessages BroadcastMessage[]

  @@unique([companyId, email])
}

model Role {
  id   String @id @default(uuid())
  name String

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  users       UserRoleMap[]
  permissions RolePermission[]

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())

  @@unique([companyId, name])
}

model Permission {
  id  String @id @default(uuid())
  key String @unique

  roles RolePermission[]

  createdAt DateTime @default(now())
}

model RolePermission {
  id String @id @default(uuid())

  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model UserRoleMap {
  id String @id @default(uuid())

  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model RefreshToken {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  token     String    @unique
  expiresAt DateTime
  revokedAt DateTime?

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// ORGANIZATION
//////////////////////////////////////////////////////

model Branch {
  id      String  @id @default(uuid())
  name    String
  address String?

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  employees Employee[]

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Department {
  id   String @id @default(uuid())
  name String

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  employees Employee[]

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  @@unique([companyId, name])
}

model Position {
  id    String @id @default(uuid())
  title String

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  employees Employee[]

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
}

//////////////////////////////////////////////////////
// EMPLOYEE
//////////////////////////////////////////////////////

model Employee {
  id         String @id @default(uuid())
  employeeNo String

  firstName  String
  middleName String?
  lastName   String

  email String?
  phone String?

  gender        String?
  maritalStatus String?
  dateOfBirth   DateTime?

  address    String?
  city       String?
  state      String?
  country    String?
  postalCode String?

  photoUrl String?

  hireDate        DateTime?
  terminationDate DateTime?

  employmentType   EmploymentType?
  employmentStatus EmploymentStatus?

  salary   Decimal? @db.Decimal(18, 2)
  currency String?  @default("NGN")

  emergencyContactName  String?
  emergencyContactPhone String?

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  branchId     String?
  departmentId String?
  positionId   String?

  branch     Branch?     @relation(fields: [branchId], references: [id], onDelete: SetNull)
  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  position   Position?   @relation(fields: [positionId], references: [id], onDelete: SetNull)

  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  wallet Wallet?

  shiftAssignments EmployeeShift[]

  attendance          AttendanceLog[]
  attendanceSummaries AttendanceSummary[]

  leaveRequests LeaveRequest[]
  loans         Loan[]
  payrolls      Payroll[]

  documents         File[]
  employeeDocuments EmployeeDocument[]
  notifications     Notification[]

  acknowledgements Acknowledgement[]
  audits           Audit[]

  assetAssignments AssetAssignment[]

  // 🔧 Performance relations
  performanceReviewsReceived PerformanceReview[] @relation("ReviewEmployee")
  performanceReviewsGiven    PerformanceReview[] @relation("ReviewReviewer")

  goals Goal[] @relation("GoalEmployee")

  feedbackReceived Feedback[] @relation("FeedbackEmployee")
  feedbackGiven    Feedback[] @relation("FeedbackReviewer")

  // 🔧 Training & Development relations
  enrollments    Enrollment[]    @relation("EmployeeEnrollments")
  certifications Certification[] @relation("EmployeeCertifications")

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  attendanceSessions AttendanceSession[]

  @@unique([companyId, employeeNo])
  @@index([companyId])
  @@index([companyId, employmentStatus])
  @@index([companyId, departmentId])
  @@index([companyId, branchId])
  @@index([companyId, positionId])
}

//////////////////////////////////////////////////////
// WALLET
//////////////////////////////////////////////////////

model Wallet {
  id String @id @default(uuid())

  employeeId String   @unique
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  balance Decimal @default(0) @db.Decimal(18, 2)

  transactions WalletTransaction[]
  ledger       WalletLedger[]

  createdAt DateTime @default(now())
}

model WalletTransaction {
  id       String @id @default(uuid())
  walletId String
  wallet   Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  type   WalletTxnType
  amount Decimal       @db.Decimal(18, 2)

  reference String?         @unique
  status    WalletTxnStatus @default(PENDING)

  createdAt DateTime @default(now())

  ledgerEntries WalletLedger[] // NEW

  @@index([walletId, createdAt])
  @@index([companyId, walletId])
  @@index([companyId, status])
}

model WalletLedger {
  id String @id @default(uuid())

  companyId String

  walletId String
  wallet   Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  transactionId String?
  transaction   WalletTransaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  debit  Decimal @db.Decimal(18, 2)
  credit Decimal @db.Decimal(18, 2)

  balanceBefore Decimal @default(0) @db.Decimal(18, 2)
  balanceAfter  Decimal @db.Decimal(18, 2)

  reference String?
  narration String?

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([walletId, createdAt])
}

//////////////////////////////////////////////////////
// LEAVE
//////////////////////////////////////////////////////

model LeaveRequest {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  approvedById String?
  approvedBy   User?   @relation(fields: [approvedById], references: [id], onDelete: SetNull)

  status LeaveStatus

  leaveTypeId String?
  leaveType   LeaveType? @relation(fields: [leaveTypeId], references: [id], onDelete: SetNull) // NEW

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([companyId, status])
}

model LeaveType {
  id   String @id @default(uuid())
  name String

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  requests LeaveRequest[]

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// ATS
//////////////////////////////////////////////////////

model Applicant {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  firstName String
  lastName  String

  email String
  phone String?

  resumeUrl    String?
  linkedinUrl  String?
  portfolioUrl String?

  applications JobApplication[]

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())

  @@unique([companyId, email])
  @@index([companyId])
}

model JobPosition {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  title       String
  description String

  isPublished Boolean   @default(false)
  expiresAt   DateTime?

  createdAt DateTime @default(now())

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  applications JobApplication[]

  @@index([companyId])
}

model JobApplication {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  applicantId String
  applicant   Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  jobId String
  job   JobPosition @relation(fields: [jobId], references: [id], onDelete: Cascade)

  status ApplicationStatus

  stageHistory ApplicationStageHistory[]

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, applicantId, jobId])
  @@index([companyId, jobId])
  @@index([companyId, status])
}

model ApplicationStageHistory {
  id String @id @default(uuid())

  companyId String

  applicationId String
  application   JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  stageId String?
  stage   RecruitmentStage? @relation(fields: [stageId], references: [id], onDelete: SetNull)

  movedAt DateTime @default(now())

  @@index([companyId])
  @@index([applicationId])
}

model RecruitmentStage {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name  String
  order Int

  stageHistories ApplicationStageHistory[]

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())

  @@unique([companyId, order])
  @@index([companyId])
}

//////////////////////////////////////////////////////
// SUBSCRIPTION
//////////////////////////////////////////////////////

model Subscription {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  planId String
  plan   SubscriptionPlan @relation(fields: [planId], references: [id])

  startsAt DateTime
  endsAt   DateTime?

  status SubscriptionStatus @default(ACTIVE)

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([companyId, status])
}

model SubscriptionPlan {
  id String @id @default(uuid())

  name  String
  price Decimal @db.Decimal(18, 2)

  maxEmployees Int?

  subscriptions Subscription[]

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// DEVICES & SETTINGS
//////////////////////////////////////////////////////

model BiometricDevice {
  id String @id @default(uuid())

  name      String
  serialNo  String @unique
  ipAddress String
  port      Int

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt      DateTime        @default(now())
  attendanceLogs AttendanceLog[]
}

model CompanySetting {
  id String @id @default(uuid())

  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  payrollEnabled   Boolean @default(true)
  biometricEnabled Boolean @default(true)
  walletEnabled    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////////////////////////////
// AUDIT & EVENTS
//////////////////////////////////////////////////////

model DomainAuditLog {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  entityType String
  entityId   String
  action     String

  before Json?
  after  Json?

  createdAt DateTime @default(now())

  @@index([companyId])
}

model DomainEvent {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  type    String
  payload Json

  processed Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([companyId])
}

//////////////////////////////////////////////////////
// PAYROLL
//////////////////////////////////////////////////////

model PayrollRun {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  periodStart DateTime
  periodEnd   DateTime

  status PayrollStatus @default(DRAFT)

  payrolls Payroll[]

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([companyId, status])
}

model Payroll {
  id String @id @default(uuid())

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  runId String
  run   PayrollRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  grossPay Decimal @db.Decimal(18, 2)
  netPay   Decimal @db.Decimal(18, 2)
  currency String  @default("NGN")

  items PayrollItem[]

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([companyId, employeeId])
}

model PayrollItem {
  id String @id @default(uuid())

  payrollId String
  payroll   Payroll @relation(fields: [payrollId], references: [id], onDelete: Cascade)

  type        PayrollItemType
  description String?
  amount      Decimal         @db.Decimal(18, 2)

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// SHIFT MANAGEMENT
//////////////////////////////////////////////////////

model Shift {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name      String
  type      ShiftType
  startTime DateTime
  endTime   DateTime

  assignments EmployeeShift[]

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt      DateTime        @default(now())
  attendanceLogs AttendanceLog[]
}

model EmployeeShift {
  id String @id @default(uuid())

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  shiftId String
  shift   Shift  @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  assignedAt DateTime @default(now())

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  @@index([employeeId])
  @@index([shiftId])
}

//////////////////////////////////////////////////////
// ATTENDANCE
//////////////////////////////////////////////////////

model AttendanceLog {
  id String @id @default(uuid())

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  punchType PunchType // NEW: IN or OUT
  timestamp DateTime  @default(now())

  deviceId String? // NEW: link to BiometricDevice
  device   BiometricDevice? @relation(fields: [deviceId], references: [id])

  shiftId String? // NEW: optional link to scheduled Shift
  shift   Shift?  @relation(fields: [shiftId], references: [id])

  sessionId String? // NEW: groups punches into one work session
  session   AttendanceSession? @relation(fields: [sessionId], references: [id])

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  @@index([companyId])
  @@index([employeeId])
  @@index([sessionId])
}

enum PunchType {
  IN
  OUT
}

model AttendanceSession {
  id String @id @default(uuid())

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  workDate    DateTime // Date the shift started
  firstIn     DateTime?
  lastOut     DateTime?
  totalHours  Decimal   @default("0.00") // ✅ Corrected
  totalEvents Int       @default(0)
  lateArrival Boolean   @default(false)

  punches AttendanceLog[] // Relation to raw punches

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
}

model AttendanceSummary {
  id String @id @default(uuid())

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  periodStart DateTime
  periodEnd   DateTime

  totalPresent Int @default(0)
  totalAbsent  Int @default(0)
  totalLate    Int @default(0)
  totalHalfDay Int @default(0)

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  @@index([companyId])
  @@index([employeeId])
}

//////////////////////////////////////////////////////
// NOTIFICATIONS
//////////////////////////////////////////////////////

model Notification {
  id String @id @default(uuid())

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  companyId String

  type    NotificationType
  message String
  read    Boolean          @default(false)

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt          DateTime          @default(now())
  broadcastMessage   BroadcastMessage? @relation(fields: [broadcastMessageId], references: [id])
  broadcastMessageId String?
}

//////////////////////////////////////////////////////
// FILES & DOCUMENTS
//////////////////////////////////////////////////////

model File {
  id String @id @default(uuid())

  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  employeeDocuments EmployeeDocument[] // NEW

  name String
  url  String

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
}

model EmployeeDocument {
  id String @id @default(uuid())

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  fileId String
  file   File   @relation(fields: [fileId], references: [id], onDelete: Cascade)

  description String?

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
}

model Loan {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  amount Decimal    @db.Decimal(18, 2)
  status LoanStatus @default(PENDING)

  issuedAt DateTime  @default(now())
  dueDate  DateTime?

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([employeeId])
}

model PerformanceReview {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation("ReviewEmployee", fields: [employeeId], references: [id], onDelete: Cascade)

  reviewerId String
  reviewer   Employee @relation("ReviewReviewer", fields: [reviewerId], references: [id], onDelete: Cascade)

  period   String
  comments String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Goal {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation("GoalEmployee", fields: [employeeId], references: [id], onDelete: Cascade)

  title       String
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Feedback {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation("FeedbackEmployee", fields: [employeeId], references: [id], onDelete: Cascade)

  reviewerId String
  reviewer   Employee @relation("FeedbackReviewer", fields: [reviewerId], references: [id], onDelete: Cascade)

  message String

  createdAt DateTime @default(now())
}

model TrainingProgram {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?

  enrollments    Enrollment[]
  certifications Certification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Enrollment {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation("EmployeeEnrollments", fields: [employeeId], references: [id], onDelete: Cascade)

  programId String
  program   TrainingProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  enrolledAt DateTime @default(now())
}

model Certification {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation("EmployeeCertifications", fields: [employeeId], references: [id], onDelete: Cascade)

  programId String
  program   TrainingProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  issuedAt  DateTime  @default(now())
  expiresAt DateTime?
}

model Policy {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  title       String
  description String?
  effectiveAt DateTime

  acknowledgements Acknowledgement[]
  audits           Audit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Acknowledgement {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  policyId String
  policy   Policy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  acknowledgedAt DateTime @default(now())
}

model Audit {
  id       String @id @default(uuid())
  policyId String
  policy   Policy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  action  String
  actorId String
  actor   Employee @relation(fields: [actorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Asset {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name         String
  description  String?
  category     String?
  serialNo     String?   @unique
  purchaseDate DateTime?
  value        Decimal?  @db.Decimal(18, 2)

  assignments AssetAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AssetAssignment {
  id      String @id @default(uuid())
  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  assignedAt DateTime  @default(now())
  returnedAt DateTime?
}

model InventoryItem {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name        String
  description String?
  quantity    Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Report {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  title String
  type  String // e.g. "Payroll", "Attendance", "Performance"
  data  Json // flexible storage for aggregated metrics

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model KPI {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name   String
  value  Float
  period String // e.g. "Q1-2026"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Integration {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  provider String // e.g. "Paystack", "BiometricDevice"
  config   Json // flexible config for API keys, endpoints

  webhooks Webhook[]
  syncs    ExternalSync[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Webhook {
  id            String      @id @default(uuid())
  integrationId String
  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  url    String
  event  String
  secret String?

  createdAt DateTime @default(now())
}

model ExternalSync {
  id            String      @id @default(uuid())
  integrationId String
  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  entity    String // e.g. "Payroll", "Attendance"
  lastRunAt DateTime?
  status    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BroadcastMessage {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  senderId String
  sender   User   @relation(fields: [senderId], references: [id], onDelete: Cascade)

  message   String
  type      NotificationType
  createdAt DateTime         @default(now())

  notifications Notification[] // link to generated notifications
}
